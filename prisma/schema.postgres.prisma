generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

enum BillStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  FULLY_PAID
  NOT_PAID
  PARTIALLY_PAID
}

enum PaymentMethodType {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  CHEQUE
  WALLET
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bills     Bill[]
  auditLogs AuditLog[]

  @@map("users")
  @@index([createdAt])
}

model Vendor {
  id        String   @id @default(cuid())
  name      String   @unique
  phone     String?
  email     String?
  address   String?
  gstin     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bills Bill[]

  @@map("vendors")
  @@index([createdAt])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#f97316")
  icon      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bills Bill[]

  @@map("categories")
  @@index([createdAt])
}

model PaymentMethod {
  id        String            @id @default(cuid())
  name      String
  type      PaymentMethodType
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  bills Bill[]

  @@map("payment_methods")
  @@index([createdAt])
}

model Bill {
  id              String     @id @default(cuid())
  billNumber      String     @unique
  billDate        DateTime
  amount          Decimal    @db.Decimal(10, 2)
  remarks         String?
  status          BillStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(NOT_PAID)
  amountPaid      Decimal       @default(0) @db.Decimal(10, 2)
  remainingAmount Decimal       @default(0) @db.Decimal(10, 2)
  submittedBy     String     @default("PUBLIC")
  submitterName   String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  vendorId        String
  vendor          Vendor        @relation(fields: [vendorId], references: [id])

  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id])

  paymentMethodId String
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  paidById        String?
  paidByUser      User?         @relation(fields: [paidById], references: [id])
  paidBy          String?

  images          BillImage[]

  @@map("bills")
  @@index([billDate])
  @@index([vendorId])
  @@index([categoryId])
  @@index([paymentMethodId])
  @@index([paidById])
  @@index([status])
  @@index([createdAt])
}

model BillImage {
  id           String   @id @default(cuid())
  url          String
  publicId     String
  thumbnailUrl String?
  createdAt    DateTime @default(now())

  billId String
  bill   Bill   @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@map("bill_images")
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  details   Json?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("audit_logs")
  @@index([createdAt])
}

model RestaurantSettings {
  id          String  @id @default(cuid())
  name        String  @default("Jay's Kitchen")
  address     String?
  phone       String?
  email       String?
  gstin       String?
  logo        String?
  currency    String  @default("USD")
  timezone    String  @default("America/New_York")

  @@map("restaurant_settings")
}
